:: Widget [widget]

<div class='settingsGrid'>
  <div id='ConsoleCheat' class='settingsToggleItemWide'>
    <details class='JSCheatConsole'>
      <summary class='JSCheatConsole'><span class='light-blue'>JavaScript <<lanSwitch 'Code Cheater' '作弊器'>></span></summary>
      <div class='searchButtons'>
        <div class='input-row'>
          <<textbox '_maplebirchJSCheatConsole' ''>>
          <<lanButton 'execute' 'capitalize'>><<run maplebirch.tool.console.execute('javascript', _maplebirchJSCheatConsole)>><</lanButton>>
        </div>
        <span id='js-cheat-console-status'></span>
      </div>
    </details>
    <details class='TwineCheatConsole'>
      <summary class='TwineCheatConsole'>
        <span class='brightpurple'>Twine <<lanSwitch 'Code Cheater' '作弊器'>></span>
      </summary>
      <div class='searchButtons'>
        <div class='input-row'>
          <<textbox '_maplebirchTwineCheatConsole' ''>>
          <<lanButton 'execute' 'capitalize'>><<run maplebirch.tool.console.execute('twine', _maplebirchTwineCheatConsole)>><</lanButton>>
        </div>
        <span id='twine-cheat-console-status'></span>
      </div>
    </details>
  </div>
</div>
<div class='settingsGrid'>
  <div class='settingsHeader options'><<lanSwitch 'Time Travel' '时间旅行'>></div>
  <<maplebirchTimeTravel>>
</div>
<div class='settingsGrid'>
  <<set $_modTransformations to Object.keys(V.maplebirch?.transformation || {})>>
  <div class='settingsHeader options'><<lanSwitch 'Mods Transformation' '模组转化'>></div>
  <<if $_modTransformations.length>>
    <div class='settingsToggleItem'>
      <span class='gold'><<lanSwitch 'Transformation Type' '转化种类'>></span><br>
      <<for _modTransformation range $_modTransformations>>
        <<capture _modTransformation>>
          <<set $_config to maplebirch.char.transformation.config.get(_modTransformation)>>
          <<if $_config?.icon>><<iconUi $_config.icon>><</if>>
          <<= maplebirch.t(_modTransformation)>>：
          <<lanLink 'set' 'capitalize'>>
            <<run maplebirch.char.transformation.setTransform(_modTransformation)>>
            <<updatesidebarimg>>
          <</lanLink>>
          |
          <<lanLink 'clear' 'capitalize'>>
            <<run maplebirch.char.transformation.setTransform(_modTransformation, 0)>>
            <<updatesidebarimg>>
          <</lanLink>>
        <</capture>>
        <br>
      <</for>>
    </div>
    <div class='settingsToggleItem'>
      <span class='gold'><<lanSwitch 'Transformation Points' '转化点数'>></span><br>
      <<for _modTransformation range $_modTransformations>>
        <<capture _modTransformation>>
          <<set $_config to maplebirch.char.transformation.config.get(_modTransformation)>>
          <<set $_title to $_config?.icon ? `<<iconUi '${$_config.icon}'>> ${maplebirch.t(_modTransformation)}` : maplebirch.t(_modTransformation)>>
          <<set $_value to V.maplebirch.transformation[_modTransformation].build ?? 0>>
          <<numberStepper $_title $_value {
            callback: (value) => {
              V.maplebirch.transformation[_modTransformation].build = value;
              maplebirch.char.transformation.updateTransform(_modTransformation);
              Wikifier.wikifyEval('<<updatesidebarimg>>');
            },
            max: $_config?.build || 100,
            percentage: false,
            colorArr: ['--teal', '--purple']
          }>>
        <</capture>>
      <</for>>
    </div>
  <</if>>
</div>
