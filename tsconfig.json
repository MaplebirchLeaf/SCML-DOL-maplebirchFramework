{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["es2022", "dom", "dom.iterable"],
    "types": ["bun", "twine-sugarcube"],
    "paths": {
      "@scml/sc2-verlnir/*": ["./node_modules/@scml/sc2-verlnir/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts", "types/**/*.d.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
